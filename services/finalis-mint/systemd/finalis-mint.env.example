FINALIS_MINT_HOST=127.0.0.1
FINALIS_MINT_PORT=8080
FINALIS_MINT_STATE_FILE=/var/lib/finalis-mint/state.json
FINALIS_MINT_MINT_ID=
FINALIS_MINT_SIGNING_SEED=finalis-mint-prod-seed
FINALIS_MINT_OPERATOR_KEY=dev-operator:1111111111111111111111111111111111111111111111111111111111111111
FINALIS_MINT_LIGHTSERVER_URL=http://127.0.0.1:19444/rpc
FINALIS_MINT_RESERVE_PRIVKEY=
FINALIS_MINT_RESERVE_ADDRESS=
FINALIS_MINT_RESERVE_FEE=1000
FINALIS_MINT_CLI_PATH=/opt/finalis-core/build/finalis-cli
FINALIS_MINT_NOTIFIER_RETRY_INTERVAL_SECONDS=5
FINALIS_MINT_SECRET_BACKEND=auto
FINALIS_MINT_NOTIFIER_SECRETS_FILE=
FINALIS_MINT_NOTIFIER_SECRET_DIR=/etc/finalis-mint/secrets.d
FINALIS_MINT_NOTIFIER_SECRET_ENV_PREFIX=FINALIS_MINT_SECRET_
FINALIS_MINT_NOTIFIER_SECRET_HELPER_CMD=/usr/local/libexec/finalis-mint-secret-helper --dir /etc/finalis-mint/secrets.d --env-prefix FINALIS_MINT_SECRET_
FINALIS_MINT_WORKER_LOCK_FILE=/run/finalis-mint/worker.lock
FINALIS_MINT_WORKER_STALE_TIMEOUT_SECONDS=30
